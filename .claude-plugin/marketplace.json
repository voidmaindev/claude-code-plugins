{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "voidmaindev-claude-code-plugins",
  "owner": {
    "name": "voidmaindev"
  },
  "metadata": {
    "description": "Claude Code plugins by voidmaindev",
    "version": "1.0.0",
    "pluginRoot": "./plugins"
  },
  "plugins": [
    {
      "name": "new-project",
      "source": "./plugins/new-project",
      "description": "Scaffold a new project with GitHub repo, CLAUDE.md, and bash shortcut",
      "version": "1.0.0",
      "author": {
        "name": "voidmaindev"
      },
      "category": "development",
      "keywords": ["scaffold", "project", "setup"]
    },
    {
      "name": "post-init",
      "source": "./plugins/post-init",
      "description": "Strip project initialization sections from CLAUDE.md after setup is complete",
      "version": "1.0.0",
      "author": {
        "name": "voidmaindev"
      },
      "category": "development",
      "keywords": ["cleanup", "init", "claude-md", "post-setup"]
    },
    {
      "name": "go-review",
      "source": "./plugins/go-review",
      "description": "Review Go codebase as a senior software architect",
      "version": "1.0.0",
      "author": {
        "name": "voidmaindev"
      },
      "category": "development",
      "keywords": ["go", "golang", "review", "architecture", "code-quality"]
    }
  ]
}
